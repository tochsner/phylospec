Alignment data = fromNexus("src/test/java/resources/primate-mtDNA.nex")

Vector<PositiveReal> diversificationRates = [1.0, 2.0]
PositiveReal turnover ~ LogNormal(mean=1.0, logSd=1.0)

Tree tree[i] ~ BirthDeath(
    diversificationRate=diversificationRates[i], turnover, taxa=taxa(data)
) for i in 1:2

