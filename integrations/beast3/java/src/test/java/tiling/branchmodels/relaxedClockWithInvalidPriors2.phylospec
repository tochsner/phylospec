Alignment alignment = fromNexus("src/test/java/resources/primate-mtDNA.nex")
Taxa taxa = taxa(alignment)
Tree tree ~ Yule(
    birthRate=1.0, taxa
)

Distribution<Vector<Rate>> dist = RelaxedClock(
    clockRate~Normal(mean=1.0, sd=2.0),
    base=LogNormal(mean=1.0, logSd=2.0),
    tree
)

