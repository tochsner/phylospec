Alignment alignment = fromNexus("src/test/java/resources/primate-mtDNA.nex")
Taxa taxa = taxa(alignment)
Tree tree ~ Yule(
    birthRate=1.0, taxa
)
Distribution<Vector<Rate>> dist = StrictClock(
    clockRate~LogNormal(logMean=1, logSd=2.0),
    tree
)
Distribution<Vector<Rate>> dist1 = StrictClock(
    clockRate~Gamma(shape=1.0, rate=2.0),
    tree
)

