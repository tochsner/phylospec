Alignment data = fromNexus("src/test/java/resources/primate-mtDNA.nex")
Tree tree1 ~ Coalescent(
    populationSize=constantPopulationFunction(
        populationSize=1.0
    ), taxa=taxa(data)
)
Tree tree2 ~ Coalescent(
    populationSize=exponentialPopulationFunction(
        populationSize~LogNormal(mean=50, logSd=2.0),
        growthRate=1.5
    ), taxa=taxa(data)
)

