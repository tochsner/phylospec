Real samplingProb ~ Beta(alpha=1.0, beta=1.0)
Real rootAge ~ LogNormal(mean=1.0, logSd=1.0)
Alignment data = fromNexus("src/test/java/resources/primate-mtDNA.nex")
Tree tree ~ BirthDeath(
    diversificationRate=1.0,
    turnover=0.5,
    samplingProbability=samplingProb,
    rootAge=rootAge,
    taxa=taxa(data)
)

