// Yule with optional rootAge argument
Real rootAge ~ Gamma(rate=1.0, shape=0.2)
Alignment data = fromNexus("src/test/java/resources/primate-mtDNA.nex")
Tree tree ~ Yule(birthRate=1.0, rootAge=rootAge, taxa=taxa(data))

