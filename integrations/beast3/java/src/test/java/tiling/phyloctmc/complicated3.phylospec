Alignment data = fromNexus("src/test/java/resources/primate-mtDNA.nex")

Tree tree ~ Yule(
    birthRate=1.0, taxa=taxa(data)
)

Vector<Rate> siteRates ~ DiscreteGammaInv(
     shape~LogNormal(mean=1.0, logSd=0.05),
     numCategories=4,
     numSites=numSites(data)
)
Alignment alignment ~ PhyloCTMC(
  tree,
  qMatrix=jc69(),
  siteRates
)
Alignment alignment2 = alignment observed as data

Integer numTaxa1 = numTaxa(alignment2)
Integer numTaxa2 = numTaxa(tree)

Integer numSites = numSites(alignment2)
Integer numBranches = numBranches(tree)

