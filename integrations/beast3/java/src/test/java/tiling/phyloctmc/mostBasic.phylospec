Alignment data = fromNexus("src/test/java/resources/primate-mtDNA.nex")
Tree tree ~ Yule(
    birthRate=1.0, taxa=taxa(data)
)
QMatrix qMatrix = jc69()

Alignment alignment ~ PhyloCTMC(
  tree, qMatrix
) observed as data

